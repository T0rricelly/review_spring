@NotNull = El campo no debe ser nulo
@NotBlank = El campo no debe ser nulo y que no este vacio
@NotEmpty = Valida que la lista no este vacia
@Min = Valida que el campo tenga un valor mayor o igual al especificado
@Max = Se usa para limitar el valor numerico maximo de campo
@Size = Valida la cantidad de caracteres
@Pattern = Valida Strings con expresiones regulares
@Email = Valida correos electronicos
@Digits = Valida la cantidad de digitos enteros y la cantidad de digitos fraccionarios
@Past = Valida que una fecha sea anterior al momento actual
@Future = Valida que una fecha sea posterior a la actual
@AssertTrue = Valida que el campo sea true
@AssertFalse = Valida que el campo sea false
@CreditCardNumber = Valida los numeros de tarjetas bancarias